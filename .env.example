# asc-mcp configuration.
#
# Copy this file to one of the auto-loaded locations and fill it in:
#   ~/.config/asc-mcp/config.env   (recommended; chmod 600)
#   ./.env                         (project-local; git-ignored)
# or set ASC_ENV_FILE=/path/to/file. Run `asc-mcp -setup` for full instructions.
#
# Where to get these: App Store Connect -> Users and Access -> Integrations ->
# App Store Connect API. Generate a key (role "App Manager" or "Admin").

# Issuer ID shown at the top of the API keys page.
ASC_ISSUER_ID=00000000-0000-0000-0000-000000000000
# Key ID of the key you generated.
ASC_KEY_ID=XXXXXXXXXX
# Path to the downloaded .p8 key file (keep it chmod 600, never commit it).
ASC_KEY_PATH=/Users/you/.config/asc-mcp/AuthKey_XXXXXXXXXX.p8
# Alternative to ASC_KEY_PATH: inline PEM with literal \n for newlines.
# ASC_PRIVATE_KEY=

# --- Optional ---------------------------------------------------------------
# Override the ASC API base URL.
# ASC_BASE_URL=https://api.appstoreconnect.apple.com

# Validate and diff without writing to App Store Connect.
# ASC_DRY_RUN=false

# Persistence (idempotency / audit / cache). Disabled by default.
# DB_ENABLED=false
# DB_DSN=postgres://user:pass@localhost:5432/asc_mcp?sslmode=disable

# Optional echo observability server (healthz/metrics). Never uses stdout.
# HTTP_ENABLED=false
# HTTP_ADDR=:8080
